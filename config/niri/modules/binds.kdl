binds {
    Mod+Shift+Slash { show-hotkey-overlay; }

    // --- Core Executions ---
    Mod+Q hotkey-overlay-title="Terminal" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$terminal'"; }
    Mod+E hotkey-overlay-title="File Explorer" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$explorer'"; }
    Mod+R hotkey-overlay-title="App Launcher" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$appmenu'"; }
    Mod+T hotkey-overlay-title="Run Command" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$commandmenu'"; }
    Mod+Y hotkey-overlay-title="Virtual Machine" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$vmanager'"; }

    Mod+A hotkey-overlay-title="Notes" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$notes'"; }
    Mod+S hotkey-overlay-title="Browser" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$browser'"; }
    Mod+G hotkey-overlay-title="Discord" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$discord'"; }
    Mod+H hotkey-overlay-title="Telegram" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$telegram'"; }

    Mod+X hotkey-overlay-title="Emoji Picker" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$emojimenu'"; }
    Mod+V hotkey-overlay-title="Clipboard" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$clipman'"; }
    Mod+B hotkey-overlay-title="OCR" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$ocr'"; }

    Mod+Grave hotkey-overlay-title="Editor" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$editor'"; }
    Mod+Shift+Grave hotkey-overlay-title="Launch Menu" { spawn-sh "sh ~/.local/share/molnios/scripts/menu/launch-menu.sh"; }
    Mod+End hotkey-overlay-title="Action Menu" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$actionmenu'"; }

    Mod+Shift+Q hotkey-overlay-title="Zellij" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$multiterminal'"; }
    Mod+Shift+E hotkey-overlay-title="Yazi CLI Explorer" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$explorercli'"; }
    Mod+Shift+R hotkey-overlay-title="Reload Wallpaper" { spawn-sh "sh ~/.local/share/molnios/scripts/wallpaper.sh -r"; }
    Mod+Shift+H hotkey-overlay-title="Wallpaper Engine" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$wallpaperengine'"; }

    Mod+Shift+G hotkey-overlay-title="Gamemode" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$gamemode'"; }
    Mod+Shift+Z hotkey-overlay-title="Coder App" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$coder'"; }
    Mod+Shift+X hotkey-overlay-title="Music Player" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$musicplayer'"; }
    Mod+Shift+C hotkey-overlay-title="Media Player (MPV)" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$player'"; }
    Mod+Shift+V hotkey-overlay-title="Bluetooth Manager" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$blueman'"; }
    Mod+Shift+B hotkey-overlay-title="Network Manager" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$netman'"; }

    Ctrl+Shift+Escape hotkey-overlay-title="Task Manager" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$task_manager'"; }

    // --- Window Actions ---
    Mod+C hotkey-overlay-title="Close Window" { close-window; }
    Mod+F hotkey-overlay-title="Fullscreen" { fullscreen-window; }
    Mod+W hotkey-overlay-title="Toggle Floating" { toggle-window-floating; }
    Mod+Shift+W hotkey-overlay-title="Toggle Tabbed Group" { toggle-column-tabbed-display; }
    Mod+Z hotkey-overlay-title="Quit Niri" { quit; }

    // Alt binds.
    Alt+Ctrl+Tab  hotkey-overlay-title="Window List" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$switchmenu'"; }

    Mod+Alt+Z hotkey-overlay-title="Eyedropper" { spawn-sh "pkill -SIGUSR1 ie-r"; }
    Mod+Alt+X hotkey-overlay-title="Eyedropper History" { spawn-sh "pkill -SIGUSR2 ie-r"; }
    Mod+Ctrl+Z hotkey-overlay-title="Reload Scripts" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$reload'"; }

    // Focus & Movement (Arrow Keys)
    Mod+Left  hotkey-overlay-title="Focus Left" { focus-column-left; }
    Mod+Down  hotkey-overlay-title="Focus Down" { focus-window-down; }
    Mod+Up    hotkey-overlay-title="Focus Up" { focus-window-up; }
    Mod+Right hotkey-overlay-title="Focus Right" { focus-column-right; }

    // Swap / Move Windows
    Mod+Shift+A hotkey-overlay-title="Move Left" { move-column-left; }
    Mod+Shift+S hotkey-overlay-title="Move Up" { move-window-up; }
    Mod+Shift+D hotkey-overlay-title="Move Down" { move-window-down; }
    Mod+Shift+F hotkey-overlay-title="Move Right" { move-column-right; }

    // Screen locking / system
    Mod+Space hotkey-overlay-title="Switch Keyboard Layout" { switch-layout "next"; }
    Mod+Escape hotkey-overlay-title="Hibernate" { spawn-sh "systemctl hybrid-sleep"; }
    Mod+Shift+Escape hotkey-overlay-title="Lock Screen" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$lock'"; }

    // --- Screenshots & Recording ---
    Print hotkey-overlay-title="Screenshot" { screenshot; }
    Ctrl+Print hotkey-overlay-title="Screenshot Window" { screenshot-window show-pointer=true; }
    Mod+Insert hotkey-overlay-title="OCR Simple" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$ocr_simple'"; }
    Mod+Print hotkey-overlay-title="Record Screen" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$record'"; }
    Mod+Shift+Print hotkey-overlay-title="Record Area" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$record -a'"; }
    Mod+Ctrl+Print hotkey-overlay-title="Record Output" { spawn-sh "sh ~/.local/share/molnios/config/niri/variables.sh '$record -o'"; }

    // --- Information Toasts (Ctrl+F1~F8) ---
    Mod+Ctrl+F1 hotkey-overlay-title="Info: Volume" { spawn-sh "notify-send -h int:transient:1 \"Volume\" \"$(wpctl get-volume @DEFAULT_AUDIO_SINK@)\""; }
    Mod+Ctrl+F2 hotkey-overlay-title="Info: Time" { spawn-sh "notify-send -h int:transient:1 \"Time\" \"$(date +%H:%M:%S)\""; }
    Mod+Ctrl+F3 hotkey-overlay-title="Info: Date" { spawn-sh "notify-send -h int:transient:1 \"Date\" \"$(date +%d.%m.%Y)\""; }
    Mod+Ctrl+F4 hotkey-overlay-title="Info: Brightness" { spawn-sh "notify-send -h int:transient:1 \"Brightness\" \"$(sh ~/.local/share/molnios/scripts/brightness.sh --get)\""; }
    Mod+Ctrl+F5 hotkey-overlay-title="Info: GPU" { spawn-sh "notify-send -h int:transient:1 \"GPU\" \"$(sh ~/.local/share/molnios/scripts/gpu.sh)\""; }
    Mod+Ctrl+F6 hotkey-overlay-title="Info: CPU" { spawn-sh "notify-send -h int:transient:1 \"CPU usage\" \"$(top -bn1 | grep 'Cpu(s)' | sed 's/.*, *\\([0-9.]*\\)%* id.*/\\1/' | awk '{printf(\"%.0f%%\",100-$1)}')\""; }
    Mod+Ctrl+F7 hotkey-overlay-title="Info: RAM" { spawn-sh "notify-send -h int:transient:1 \"RAM usage\" \"$(free | awk '/Mem:/{printf(\"%.0f%%\",$3/$2*100)}')\""; }
    Mod+Ctrl+F8 hotkey-overlay-title="Info: Disk" { spawn-sh "notify-send -h int:transient:1 \"Disk\" \"$(sh ~/.local/share/molnios/scripts/disk.sh)\""; }
    Mod+Ctrl+F9 hotkey-overlay-title="Info: Temp" { spawn-sh "notify-send -h int:transient:1 \"Temp\" \"$(sh ~/.local/share/molnios/scripts/temp.sh)\""; }

    // --- Desktop Keyboard F-Row Media & Brightness ---
    Mod+Shift+F1 allow-when-locked=true hotkey-overlay-title="Volume Down" { spawn-sh "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%-"; }
    Mod+Shift+F2 allow-when-locked=true hotkey-overlay-title="Volume Up" { spawn-sh "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+"; }
    Mod+Shift+F3 allow-when-locked=true hotkey-overlay-title="Mute" { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    Mod+Shift+F4 allow-when-locked=true hotkey-overlay-title="Mic Mute" { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }
    Mod+Shift+F5 allow-when-locked=true hotkey-overlay-title="Brightness Down" { spawn-sh "sh ~/.local/share/molnios/scripts/brightness.sh -10%"; }
    Mod+Shift+F6 allow-when-locked=true hotkey-overlay-title="Brightness Up" { spawn-sh "sh ~/.local/share/molnios/scripts/brightness.sh +10%"; }

    // --- Laptop Media & Brightness (Locked + Repeating) ---
    XF86AudioRaiseVolume allow-when-locked=true hotkey-overlay-title="Volume Up" { spawn-sh "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+"; }
    XF86AudioLowerVolume allow-when-locked=true hotkey-overlay-title="Volume Down" { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"; }
    XF86AudioMute        allow-when-locked=true hotkey-overlay-title="Mute" { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true hotkey-overlay-title="Mic Mute" { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }
    XF86MonBrightnessUp  allow-when-locked=true hotkey-overlay-title="Brightness Up" { spawn-sh "brightnessctl -q s 10%+"; }
    XF86MonBrightnessDown allow-when-locked=true hotkey-overlay-title="Brightness Down" { spawn-sh "brightnessctl -q s 10%-"; }
    Mod+J allow-when-locked=true hotkey-overlay-title="Media Prev" { spawn-sh "playerctl previous"; }
    Mod+K allow-when-locked=true hotkey-overlay-title="Media Pause" { spawn-sh "playerctl play-pause"; }
    Mod+L allow-when-locked=true hotkey-overlay-title="Media Next" { spawn-sh "playerctl next"; }

    // --- Workspaces ---
    Mod+D hotkey-overlay-title="Overview" { toggle-overview; }
    Mod+P hotkey-overlay-title="Merge/Expel Window" { consume-or-expel-window-left; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
}