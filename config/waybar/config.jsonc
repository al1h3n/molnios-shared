{
	"include": [
		// L-Modules.
		"~/waybar/waybar/modules/menu.jsonc",
		"~/waybar/waybar/modules/clock.jsonc",
		"~/waybar/waybar/modules/weather.jsonc",
		"~/waybar/waybar/modules/media.jsonc",

		// M-Modules.
		"~/waybar/waybar/modules/window-manager.jsonc",


		// R-Modules.
		"~/waybar/waybar/modules/tray.jsonc",
		"~/waybar/waybar/modules/volume.jsonc",
		"~/waybar/waybar/modules/network.jsonc",
		"~/waybar/waybar/modules/language.jsonc",
		"~/waybar/waybar/modules/brightness.jsonc",
		"~/waybar/waybar/modules/battery.jsonc",
		"~/waybar/waybar/modules/notification.jsonc"
	],

	// Modules.

	"modules-left": [
		"custom/menu",
		"clock#macos",
		"custom/weather",
		"hyprland/window",
		"mpris"
	],
	"modules-center": [
		"hyprland/workspaces#main"
	],
	"modules-right": [
		"tray",
		"group/pulseaudio",
		"network",
		// "bluetooth",
		"hyprland/language",
		"backlight",
		"battery",
		"custom/notification"
	],

	// Waybar options.
	"spacing": 3,
	"name": "molni-waybar",
	"mode": "dock",
	"layer": "top",
	"reload_style_on_change": true // Only works with .CSS
}