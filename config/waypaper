[Settings]
folder = ~/.local/share/molnios/molnios-media/wallpapers/video
wallpaper = ~/.local/share/molnios/molnios-media/wallpapers/video/ps.mp4
post_command = sh ~/.local/share/molnios/scripts/borderline.sh $wallpaper $video
number_of_columns = 5
swww_transition_type = random
swww_transition_fps = 144
mpvpaper_options = -s -o "--loop --mute --no-osd-bar --no-input-default-bindings" ALL $video
stylesheet = ~/.local/share/molnios/config/waypaperstyle
fill = stretch
subfolders = True
all_subfolders = True
show_hidden = True
mpvpaper_sound = False