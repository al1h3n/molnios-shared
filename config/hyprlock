# 6.1. Song album.
image {
    size = 75
    rounding = 25
    border_size = 0
    reload_time = 1
    reload_cmd = sh ~/.local/share/molnios/scripts/hyprsong.sh --art
    position = -5.75%, 9.35%
    valign = bottom
    zindex = 1

    shadow_passes = 2
    shadow_size = 3
    shadow_color = $shadow
    shadow_boost = .8
}

# 6.2. Backgrounds.
shape {
    #6.2.1. Music player square.
    color = $glass
    border_size = 1
    border_color = $border
    size = 4%, 2.25%
    rounding = 35
    position = 0, 16.25%
    valign = bottom

    shadow_passes = 2
    shadow_size = 3
    shadow_color = $shadow
    shadow_boost = 1
}

shape {
    #6.2.1. Main player.
    color = $glass
    border_size = 1
    border_color = $border
    size = 15.5%, 12.4%
    rounding = 35
    position = 0, 3.1%
    valign = bottom

    shadow_passes = 2
    shadow_size = 3
    shadow_color = $shadow
    shadow_boost = 1
}

# 6.3. Player source. (e.g., Spotify, Firefox)
label {
    text = cmd[update:100] echo "$(sh ~/.local/share/molnios/scripts/hyprsong.sh --player)"
    color = rgba(216, 222, 233, 0.70)
    font_size = 13
    font_family = SF Pro Display Bold
    position = 0, 16.725%
    valign = bottom
    zindex = 2
}

# 6.4. Headers.

# 6.4.1. Song title.
label {
    text = cmd[update:100] echo "$(sh ~/.local/share/molnios/scripts/hyprsong.sh --title)"
    color = rgba(216, 222, 233, 0.70)
    font_size = 14
    font_family = SF Pro Display Heavy
    position = 46.25%, 12%
    text_align = left
    halign = left
    valign = bottom
    zindex = 1
}

# 6.4.2. Artist name
label {
    text = cmd[update:100] echo "󰠃  $(sh ~/.local/share/molnios/scripts/hyprsong.sh --artist)"
    color = rgba(216, 222, 233, 0.70)
    font_size = 12
    font_family = SF Pro Display
    text_align = left
    position = 46.25%, 10.75%
    halign = left
    valign = bottom
    zindex = 1
}

# 6.5. Progress bar.

# 6.5.1. Current position timestamp.
label {
    text = cmd[update:100] echo "$(sh ~/.local/share/molnios/scripts/hyprsong.sh --position)"
    color = rgba(216, 222, 233, 0.70)
    font_size = 10
    font_family = SF Pro Display Medium
    position = -5.6%, 6.8%
    valign = bottom
}

# 6.5.2. Progress bar (with Pango markup for colored segments).
label {
    text = cmd[update:100] sh ~/.local/share/molnios/scripts/hyprsong.sh --progress-bar
    color = rgba(216, 222, 233, 0.70)
    font_size = 14
    font_family = SF Pro Display Medium
    position = 0, 6.6%
    valign = bottom
}

# 6.5.3. Total length timestamp.
label {
    text = cmd[update:100] echo "$(sh ~/.local/share/molnios/scripts/hyprsong.sh --length)"
    color = rgba(216, 222, 233, 0.70)
    font_size = 10
    font_family = SF Pro Display Medium
    position = 5.6%, 6.8%
    valign = bottom
}

# 6.6. Playback Controls.

# 6.6.1. Previous track button.
label {
    text = 󰒮
    color = $white_transparent
    font_size = 25
    onclick = playerctl previous
    position = -2%, 3.85%
    valign = bottom
}

# 6.6.2. Play/Pause button.
label {
    text = cmd[update:100] sh ~/.local/share/molnios/scripts/hyprsong.sh --status
    color = $white_transparent
    font_size = 25
    onclick = playerctl play-pause
    position = 0, 3.85%
    valign = bottom
}

# 6.6.3. Next track button.
label {
    text = 󰒭
    color = $white_transparent
    font_size = 25
    onclick = playerctl next
    position = 2%, 3.85%
    valign = bottom
}

