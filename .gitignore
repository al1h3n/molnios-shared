# =========================
# FOLDERS TO IGNORE
# =========================
node_modules/
dist/
coverage/
.env/
.vscode/
.idea/
logs/
tmp/
.cache/

# Ignore nested folders anywhere
**/output/
**/generated/

# =========================
# FILE EXTENSIONS TO IGNORE
# =========================
*.log
*.tmp
*.bak
*.swp
*.cache
*.pid
*.lock

# Compiled / binary files
*.exe
*.dll
*.so
*.dylib
*.class
*.jar

# =========================
# ENV & SECRET FILES
# =========================
.env
.env.*
*.key
*.pem

# =========================
# OS-SPECIFIC FILES
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# LANGUAGE / TOOL SPECIFIC
# =========================

# Python
__pycache__/
*.pyc
*.pyo

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java / Kotlin
.gradle/

# =========================
# CUSTOM EXAMPLES
# =========================

# Ignore specific file
secret-config.json

# Ignore all files in a folder but keep the folder
important-folder/*
!important-folder/.keep

# Ignore everything in logs except .gitkeep
logs/*
!logs/.gitkeep

