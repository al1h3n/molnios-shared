# 7. Internet.
label {
    text = cmd[update:100] echo "$(sh ~/.local/share/molnios/scripts/inet.sh)"
    text_align = right
    color = $foreground
    font_size = 24
    font_family = SF Pro Display Semi-Bold
    position = 1%, -1.125%
    halign = left
    valign = top
}

# 8. Battery.
label {
    text = cmd[update:100] echo "$(sh ~/.local/share/molnios/scripts/battery.sh)"
    text_align = right
    color = $foreground
    font_size = 24
    font_family = SF Pro Display Semi-Bold
    position = -1%, -1.125%
    halign = right
    valign = top
}

# 9. Power Menu (Bottom Right)
# 9.1. Background shape (main)
shape {
    color = $glass
    border_size = 1
    border_color = $border
    size = 6%, 3.5%
    rounding = 25
    position = -4%, 1.125%
    halign = right
    valign = bottom

    shadow_passes = 2
    shadow_size = 3
    shadow_color = $shadow
    shadow_boost = 1
}

# 9.2. Background shape (shutdown button)
shape {
    color = $glass
    border_size = 1
    border_color = $border
    size = 2%, 3.5%
    rounding = 25
    position = -1.375%, 1.125%
    halign = right
    valign = bottom

    shadow_passes = 2
    shadow_size = 3
    shadow_color = $shadow
    shadow_boost = 1
}

# 9.3. Logout button.
label {
    text = <span>󰈆 </span>
    color = $white
    font_size = 23
    font_family = SF Pro Display
    position = -8%, 1.65%
    halign = right
    valign = bottom
    zindex = 2
    onclick = hyprctl dispatch exit
}

# 9.4. Hibernate button.
label {
    text = <span> </span>
    color = $white
    font_size = 22
    font_family = SF Pro Display
    position = -6%, 1.75%
    halign = right
    valign = bottom
    zindex = 2
    onclick = systemctl hibernate
}

# 9.5. Reboot button.
label {
    text = <span> </span>
    color = $white
    font_size = 23
    font_family = SF Pro Display
    position = -4%, 1.65%
    halign = right
    valign = bottom
    zindex = 2
    onclick = systemctl reboot
}

# 9.6. Shutdown button.
label {
    text = <span> </span>
    color = $white
    font_size = 22
    font_family = SF Pro Display
    position = -1.5%, 1.8%
    halign = right
    valign = bottom
    zindex = 2
    onclick = systemctl poweroff
}
