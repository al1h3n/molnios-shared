{
	"backlight": {
		"format": "{icon} {percent}%",
		"format-icons": [
			"юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"
		],
		"on-scroll-up": "sh ~/.local/share/molnios/scripts/mechabar/backlight.sh up",
		"on-scroll-down": "sh ~/.local/share/molnios/scripts/mechabar/backlight.sh down"
	}
}