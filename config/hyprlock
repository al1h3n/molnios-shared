# ==========================================================
# hyprlock.conf al1h3n edition - v1
# Changed: first release.
# ==========================================================

# Path - ~/.config/hypr/hyprlock
# Launch by "hyprlock -q"

# THE GLOW EFFECT
# shadow_passes = 3       # 3 or 4 creates a nice soft glow
# shadow_size = 5         # Distance/Spread of the glow
# shadow_color = $shadow # Glow (change to match your theme)
# shadow_boost = 1.2      # Makes it brighter

# 0. Pre defining colors.
# 1.1. Main.
$white =rgb(255, 255, 255)
$test = rgb(31, 137, 153)

# 1.2. RGBA colors.
$null = rgba(0, 0, 0, 0)
$white_transparent = rgba(255, 255, 255, .55)
$white_transparent_extra = rgba(255, 255, 255, .3)
$gray_transparent = rgba(80, 80, 80, .9)
$black_transparent = rgba(0, 0, 0, .75)
$red_transparent = rgba(255, 0, 0, .5)

# 1.3. Main definitions.
$media_player = rgba(255, 255, 255, .5)
$checking_color = $red_transparent
$foreground = $white_transparent
$background = $test

# Liquid glass.
$shadow = rgba(0, 0, 0, .3)
$border = rgba(255, 255, 255, .2)
$glass = rgba(255, 255, 255, 0.1)
$glass_less = rgba(255, 255, 255, 0.4)

# 1. Animations.
animations {
    # Fading to main window.
    bezier = linear, 1, 1, 0, 0
    animation = fade, 1, 2.5, linear
}

# 2. Background image/color.
background {
    color = $background
    path = ~/.local/share/molnios/wallpapers/static/tahoe.jpg # Change to "color = $background" or "path = screenshot".
    blur_passes = 2
    blur_size = 2
    brightness = .75
    vibrancy = .2
    vibrancy_darkness = .1
}

# 3. Password field.
input-field {
    size = 15%, 4.5%
    dots_size = .2
    dots_color = $black_transparent
    dots_spacing = .35
    font_family = SF Pro Display Bold
    outer_color = $white_transparent_extra
    inner_color = $glass
    font_color = $white
    fade_on_empty = false
    check_color = $checking_color
    fail_text = Insanity is doing the <b>exact same</b> thing <b>over</b> and <b>over</b> again and expecting different results - wrong attempts ($ATTEMPTS).
    placeholder_text = Open sesame..
    position = 0, -17.5%

    shadow_passes = 3
    shadow_size = 10
    shadow_color = $shadow
    shadow_boost = .8
}

# 4. Lock icon.

label {
    text = <span> </span>
    color = $white_transparent_extra
    font_size = 30
    font_family = SF Pro Display Bold
    position = 2, -5%
    valign = top

    shadow_passes = 3
    shadow_size = 10
    shadow_color = $shadow
    shadow_boost = .8
}

# 4.1. Date.
label {
    text = cmd[update:100] echo $(date +"%A, %B %d")
    color = $white_transparent # Change this if not visible.
    font_size = 40
    font_family = SF Pro Display Bold
    position = 0, -10%
    valign = top

    shadow_passes = 3
    shadow_size = 10
    shadow_color = $shadow
    shadow_boost = .8
}

# 4.2.. Time.
label {
    text = cmd[update:100] echo $(date +"%-I:%M")
    color = $white_transparent # Change this if not visible.
    font_size = 250
    font_family = SF Pro Display Ultra-Bold
    position = 0, -11%
    valign = top

    shadow_passes = 3
    shadow_size = 10
    shadow_color = $shadow
    shadow_boost = .8
}


# 5.1. Account (name).
label {
    text = cmd[update:100] echo "$(whoami)"
    color = $white
    font_size = 20
    font_family = SF Pro Display Bold
    position = 0, -12%

    shadow_passes = 3
    shadow_size = 10
    shadow_color = $shadow
    shadow_boost = .8
}

# 5.2. Profile picture.
label {
    text = <span> </span>
    color = $white_transparent
    font_size = 80
    font_family = SF Pro Display Bold
    position = .6%, -6.75%

    shadow_passes = 3
    shadow_size = 10
    shadow_color = $shadow
    shadow_boost = .8
}

# 6. Media player.

# Simple variant
# label {
#     text = cmd[update:100] echo "$(sh ~/.al1h3n/song.sh)"
#     color = $media_player
