{
  "layer": "top",
  "font": "SF Pro",
  "cssPriority": "user",
  "fit-to-screen": false,
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-width": 500,
  "control-center-height": -1,

  "notification-window-width": 500,

  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "image-visibility": "when-available",

  "timeout": 8,
  "timeout-low": 2,
  "notification-2fa-action": true,
  "notification-inline-replies": true,

  "keyboard-shortcuts": true,

  "text-empty": "Nothing to see here",

  "scripts": {
    "notify-sound": {
      "exec": "~/.local/share/molnios/scripts/notify/beeper.sh"
    }
  },

  "widgets": [
    "buttons-grid",
    "backlight",
    "volume",
    "inhibitors",
    "dnd",
    "notifications",
    "mpris"
  ],
  "widget-config": {
    "notifications": {
      "vexpand": true
    },
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "Clear",
      "clear-all-button": true
    },
    "title": {
      "text": "MolniOS center",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "mpris": {
      "blacklist": ["firefox", "spotify"],
      "autohide": true,
      "show-album-art": "always"
    },
    "backlight": {
      "label": "󰃟",
      "slider": true,
      "min": 10
    },
    "volume": {
      "label": "",
      "slider": true
    },
    "buttons-grid": {
      "buttons-per-row": 5,
      "actions": [
        {
          "label": "󰤨",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
          "update-command": "sh -c '[[ $(nmcli radio wifi) == \"enabled\" ]] && echo true || echo false'"
        },
        {
          "label": "󰂯",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && bluetooth on || bluetooth off'",
          "update-command": "sh $L_PATH/scripts/monitor/bluetooth-status.sh"
        },
        {
          "label": "󰈀",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli networking on || nmcli networking off'",
          "update-command": "sh -c '[[ $(nmcli networking connectivity) != \"none\" ]] && echo true || echo false'"
        },
        {
          "label": "󱧥",
          "type": "toggle",
          "active": false,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && pkexec tlp bat || pkexec tlp ac'",
          "update-command": "sh $L_PATH/scripts/tlp-status.sh"
        },
        {
          "label": "󰖂",
          "type": "toggle",
          "active": false,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && warp-cli connect || warp-cli disconnect'",
          "update-command": "sh -c 'warp-cli status | grep -q \"Connected\" && echo true || echo false'"
        },
        {
          "label": "",
          "type": "command",
          "command": "sh $L_PATH/scripts/shazam.sh"
        },
        {
          "label": "",
          "type": "command",
          "command": "sh -c 'if command -v wezterm >/dev/null 2>&1; then wezterm --config-file $L_PATH/config/wezterm/wezterm.lua; elif command -v kitty >/dev/null 2>&1; then kitty -c $L_PATH/config/kitty/kitty.conf; elif command -v alacritty >/dev/null 2>&1; then alacritty; fi'"
        },
        {
          "label": "󰍃",
          "type": "command",
          "command": "wlogout -nl $L_PATH/config/wlogout/layout -C $L_PATH/config/wlogout/wlogout.css"
        }
      ]
    }
  }
}
