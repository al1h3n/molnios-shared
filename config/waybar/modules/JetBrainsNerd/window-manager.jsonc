/*
window - current window title.
workspaces - your current opened workspaces.
language - current layout
*/

{
    "hyprland/window": {
        "max-length": 25,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "َ°ˆ¹ $1",
            "(.*) - VSCode": "َ°¨‍ $1",
            "(.*) - VSCodium": "َ°¨‍ $1",
            "(.*) - Notion": "î،ˆ $1",
            "nvim(.*)": "ïچ¯ $1",
            "Minecraft(.*)": "َ°چ³$1",
            "Prism Launcher(.*)": "َ°چ³$1",
            "OBS(.*)": "ï€½ $1",
            "Spotify(.*)": "ï†¼ Spotify",
            "qBittorrent(.*)": "qBittorrent $1",
            "Telegram(.*)": "ï‹†$1",
            "(.*)Discord(.*)": "ï‡؟  $1",
            "Steam(.*)": "ï†¶ Steam $1",
            "(.*) - Thunar": "ïپ» $1",
            "(.*)LocalSend(.*)": "ï”ژ $1",
            "sh": "َ°†چ $1",
            "bash": "َ°†چ $1",
            "zsh": "َ°†چ $1",
            "Yazi(.*)": "ïپ» $1",
            "superfile(.*)": "ïپ» Superfile $1",
            "": "MolniOS"
        },
        "separate-outputs": true
    },

    "niri/window": {
        "max-length": 25,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "َ°ˆ¹ $1",
            "(.*) - VSCode": "َ°¨‍ $1",
            "(.*) - VSCodium": "َ°¨‍ $1",
            "(.*) - Notion": "î،ˆ $1",
            "nvim(.*)": "ïچ¯ $1",
            "Minecraft(.*)": "َ°چ³$1",
            "Prism Launcher(.*)": "َ°چ³$1",
            "OBS(.*)": "ï€½ $1",
            "Spotify(.*)": "ï†¼ Spotify",
            "qBittorrent(.*)": "qBittorrent $1",
            "Telegram(.*)": "ï‹†$1",
            "(.*)Discord(.*)": "ï‡؟  $1",
            "Steam(.*)": "ï†¶ Steam $1",
            "(.*) - Thunar": "ïپ» $1",
            "(.*)LocalSend(.*)": "ï”ژ $1",
            "sh": "َ°†چ $1",
            "bash": "َ°†چ $1",
            "zsh": "َ°†چ $1",
            "Yazi(.*)": "ïپ» $1",
            "superfile(.*)": "ïپ» Superfile $1",
            "": "MolniOS"
        },
        "separate-outputs": true
    },

    "hyprland/workspaces#aqua": {
        "format": "{icon}",
        "format-icons": {
          // "default": "ï„Œ",
          "default": "î®ٹ",
          "active": "ï„‘"
        },
        "persistent-workspaces": {
          "*": [ 1, 2, 3 ]
        },
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch \"hl.dsp.focus({ workspace = 'e+1' })\"",
        "on-scroll-down": "hyprctl dispatch \"hl.dsp.focus({ workspace = 'e-1' })\"",
        "tooltip-format": "Workspace {name}\n{windows}"
    },

    "hyprland/workspaces#main": {
        "persistent-workspaces": {
          "*": [ 1, 2, 3, 4, 5 ]
        },
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch \"hl.dsp.focus({ workspace = 'e+1' })\"",
        "on-scroll-down": "hyprctl dispatch \"hl.dsp.focus({ workspace = 'e-1' })\"",
        "tooltip-format": "Workspace {name}\n{windows}"
    },

    "niri/workspaces#aqua": {
        "format": "{icon}",
        "format-icons": {
          // "default": "ï„Œ",
          "default": "î®ٹ",
          "active": "ï„‘"
        },
        "persistent-workspaces": {
          "*": [ 1, 2, 3 ]
        },
        "on-click": "activate",
        "on-scroll-up": "niri msg action focus-workspace-up",
        "on-scroll-down": "niri msg action focus-workspace-down",
        "tooltip-format": "Workspace {name}\n{windows}"
    },

    "niri/workspaces#main": {
        "persistent-workspaces": {
          "*": [ 1, 2, 3, 4, 5 ]
        },
        "on-click": "activate",
        "on-scroll-up": "niri msg action focus-workspace-up",
        "on-scroll-down": "niri msg action focus-workspace-down",
        "tooltip-format": "Workspace {name}\n{windows}"
    }
}