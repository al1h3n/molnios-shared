layout {
    gaps 8 // Hyprland used in=4, out=5. Niri uses unified gaps.

    // Hyprland border_size = 2, rounding = 10
    focus-ring {
        width 2
        active-color "#FFFFFF40"
        inactive-color "#1A1A1A90"
    }

    // Shadow range 25
    shadow {
        on
        softness 25 // Softness controls the shadow blur radius.
        spread 3 // Spread expands the shadow.
        offset x=0 y=2
        color "#1A1A1A90"
    }
}
